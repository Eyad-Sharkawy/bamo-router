{
  "name": "bamo-router",
  "version": "2.1.0",
  "description": "Desktop app to manage your Bamo home router",
  "author": "Bamo",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:web": "ng build --configuration production",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:icon": "node scripts/generate-icon.mjs",
    "build:app": "npm run build:web && npm run build:electron",
    "clean:release": "node scripts/prepare-release.mjs",
    "dist": "npm run clean:release && npm run build:app && node scripts/run-electron-builder.mjs",
    "dist:win": "npm run clean:release && npm run build:app && node scripts/run-electron-builder.mjs --win",
    "dist:win:alt": "npm run build:app && node scripts/run-electron-builder.mjs --win",
    "force:clean": "powershell -ExecutionPolicy Bypass -File scripts/force-clean-release.ps1",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "watch:electron": "tsc -p electron/tsconfig.json -w",
    "start:electron": "wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .",
    "dev": "npm run build:electron && concurrently -k \"npm run watch:electron\" \"ng serve\" \"npm run start:electron\""
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "axios": "^1.16.1",
    "axios-cookiejar-support": "^7.0.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^28.0.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.12",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.10"
  }
}
